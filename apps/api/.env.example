# ── Base de datos ──────────────────────────────────────────────────────────────
# Pooler URL de Supabase (puerto 6543) — usa pgbouncer=true
DATABASE_URL=postgresql://postgres.XXXXXXXX:PASSWORD@aws-0-XX.pooler.supabase.com:6543/postgres?pgbouncer=true

# URL directa de Supabase (puerto 5432) — solo para prisma db push / migraciones
DIRECT_URL=postgresql://postgres.XXXXXXXX:PASSWORD@aws-0-XX.pooler.supabase.com:5432/postgres

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-una-cadena-muy-larga-y-aleatoria

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ── Supabase Storage ───────────────────────────────────────────────────────────
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_KEY=eyJhbGci...   # service_role key (Settings → API)

# ── Resend (emails) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── CORS ───────────────────────────────────────────────────────────────────────
# URL del frontend en Vercel, separada por comas si hay más de una
CORS_ORIGIN=http://localhost:3000
