generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OWNER
  TENANT
  TECHNICIAN
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  name       String
  role       Role       @default(TENANT)
  properties Property[] @relation("OwnerProperties")
  leases     Lease[]
  tickets    Ticket[]
  createdAt  DateTime   @default(now())
}

model Property {
  id          String   @id @default(uuid())
  address     String
  city        String
  description String?
  ownerId     String
  owner       User     @relation("OwnerProperties", fields: [ownerId], references: [id])
  leases      Lease[]
  tickets     Ticket[]
}

model Lease {
  id         String   @id @default(uuid())
  startDate  DateTime
  endDate    DateTime
  rentAmount Float
  tenantId   String
  tenant     User     @relation(fields: [tenantId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
}

model Ticket {
  id          String   @id @default(uuid())
  description String
  category    String?  // Detectado por IA (Plomería, Eléctrico, etc.)
  priority    String?  // Detectado por IA (Urgente, Alta, Media, Baja)
  aiSummary   String?  // Resumen técnico hecho por la IA
  status      String   @default("OPEN")
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
  reporterId  String?
  reporter    User?     @relation(fields: [reporterId], references: [id])
  createdAt   DateTime @default(now())
}